#!/usr/bin/env bash
#
# Enforce Conventional Commits on the subject line. Merge commits created by
# git (and GitHub squash/merge) are exempt.
set -euo pipefail

msg_file="${1:-}"
[ -f "$msg_file" ] || exit 0

# First non-comment, non-blank line is the subject.
subject="$(grep -vE '^#' "$msg_file" | sed '/^$/d' | head -n1)"

# Exempt git-generated merge commits.
case "$subject" in
  "Merge "* | "Merge branch"*) exit 0 ;;
esac

types="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|merge"
if ! printf '%s' "$subject" | grep -Eq "^($types)(\([a-z0-9._-]+\))?!?: .+"; then
  echo "commit-msg: subject line does not follow Conventional Commits:" >&2
  echo "  $subject" >&2
  echo "Expected: <type>(<scope>): <description>" >&2
  echo "Types: $types" >&2
  exit 1
fi
